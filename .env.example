# HyperSwitch publishable key (browser-safe, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_HYPERSWITCH_PUBLISHABLE_KEY=pk_snd_replace_me

# HyperSwitch secret API key (server-only, used by /api/create-payment)
HYPERSWITCH_API_KEY=snd_replace_me

# HyperSwitch profile ID (used by /api/create-payment)
NEXT_PUBLIC_PROFILE_ID=pro_replace_me

# Base API URL — sandbox or production
HYPERSWITCH_API_URL=https://sandbox.hyperswitch.io

# Backend server URL (mockServer.cjs) — use http://localhost:5252 for web dev
# For Android emulator use http://10.0.2.2:5252
# For iOS simulator use http://localhost:5252
NEXT_PUBLIC_SERVER_URL=http://localhost:5252
